<%- include ("../partials/studentHeader.ejs") %>
<% if (typeof message !== 'undefined' && message) { %>
  <div style="margin: 1rem 2rem; padding: 12px 18px; border-radius: 10px; 
    background: <%= message.includes('Success') || message.includes('enrolled') && !message.includes('already') ? 'rgba(40,167,69,0.15)' : 'rgba(220,53,69,0.15)' %>;
    color: <%= message.includes('Success') || message.includes('enrolled') && !message.includes('already') ? '#5cb85c' : '#ff6b7a' %>;
    border: 1px solid <%= message.includes('Success') || message.includes('enrolled') && !message.includes('already') ? 'rgba(40,167,69,0.3)' : 'rgba(220,53,69,0.3)' %>;
    font-weight:600;">
    <%= message.includes('Success') ? '✅' : '⚠️' %> <%= message.replace(/\+/g, ' ') %>
  </div>
<% } %>

<div class="page-title-bar">
    <div class="page-title-icon">🎯</div>
    <div>
        <h2>Course Enrollment</h2>
        <p>Select a course to enroll for the upcoming semester</p>
    </div>
</div>

<div class="form_container">
    <div class="add_student_form" style="max-width: 500px">
        <form action="/enrollments/enroll" method="POST">
            
            <div class="form-group">
                <label for="course_id">Available Courses</label>
                <select id="course_id" name="course_id" required>
                    <option value="" disabled selected>-- Select a Course --</option>
                    <% courses.forEach(function(c) { 
                        const alreadyEnrolled = enrolledIds.includes(c.course_id);
                    %>
                        <option value="<%= c.course_id %>" <%= alreadyEnrolled ? 'disabled style="color:#888"' : '' %>>
                            <%= c.course_name %><%= alreadyEnrolled ? ' ✓ (enrolled)' : '' %>
                        </option>
                    <% }); %>
                </select>
            </div>

            <button type="submit" class="sbtbtn" id="submitBtn">📢 Enroll Now</button>
        </form>

        <% if (enrolledIds.length > 0) { %>
        <div style="margin-top: 2rem; padding: 1rem 1.2rem; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px;">
            <p style="margin:0 0 0.6rem 0; font-size:0.85rem; color:var(--text-soft); text-transform:uppercase; letter-spacing:0.06em;">✅ Already Enrolled In</p>
            <% courses.filter(function(c){ return enrolledIds.includes(c.course_id); }).forEach(function(c){ %>
                <span style="display:inline-block; background:var(--primary-accent); color:#fff; padding:4px 14px; border-radius:999px; font-size:0.82rem; margin:3px 4px 3px 0; font-weight:600;"><%= c.course_name %></span>
            <% }); %>
        </div>
        <% } %>
    </div>
</div>
<%- include ("../partials/footer.ejs") %>
