<%- include ("../partials/header.ejs") %>

        <div class="page-title-bar">
            <div class="page-title-icon">📋</div>
            <div>
                <h2>All Students</h2>
                <p>Complete list of enrolled students — <%= students.length %> record<%= students.length !== 1 ? 's' : '' %> found</p>
            </div>
        </div>

<div class="students_container">
    <% students.forEach((student, i) => { %>
        <div class="student_card" style="--i:<%= i %>">

            <h3 class="name"><%= student.name %></h3>

            <p><strong>ID:</strong> <%= student.id %></p>
            <p><strong>Age:</strong> <%= student.age %> years</p>
            <p><strong>📞 Phone:</strong> <%= student.phone %></p>

            <div class="phone_year">
                <p><strong>Branch</strong><br><%= student.branch %></p>
                <p><strong>Year</strong><br><%= student.year %></p>
            </div>

            <p><strong>📘 Courses:</strong> <%= student.courses %></p>

            <p class="cgpa">⭐ CGPA: <%= student.cgpa %></p>

            <% if (user?.role === "teacher" || user?.role === "admin") { %>
                <a href="/students/editStudent/<%= student.id %>" class="sbtbtn" style="text-align:center; text-decoration:none; display:inline-block; margin-top:10px;">✎ Edit Student</a>
            <% } %>

        </div>
    <% }) %>
</div>

<%- include ("../partials/footer.ejs") %>
