<%- include ("../partials/header.ejs") %>

        <div class="page-title-bar">
            <div class="page-title-icon">➕</div>
            <div>
                <h2>Add New Student</h2>
                <p>Fill in all the details to register a student in the system</p>
            </div>
        </div>

        <div class="form_container">
            <div class="add_student_form">

                <div class="form-header">
                    <h2>Student Registration</h2>
                    <p>All fields are required. Login credentials auto-generated: <strong>phone@srms.edu</strong> / roll number</p>
                </div>

                <div class="form-group">
                    <label for="studentId">Student Roll Number</label>
                    <input type="text" id="studentId" placeholder="e.g., AP24110011724">
                </div>

                <div class="form-group">
                    <label for="studentName">Full Name</label>
                    <input type="text" id="studentName" placeholder="e.g., John Doe">
                </div>

                <div class="form-group">
                    <label for="studentAge">Age</label>
                    <input type="number" id="studentAge" placeholder="e.g., 20" min="16" max="30">
                </div>

                <div class="form-group">
                    <label for="branch">Branch / Department</label>
                    <select id="branch">
                        <option value="CSE">Computer Science (CSE)</option>
                        <option value="ECE">Electronics &amp; Comm. (ECE)</option>
                        <option value="MECH">Mechanical (MECH)</option>
                        <option value="CIVIL">Civil Engineering</option>
                        <option value="EEE">Electrical (EEE)</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="year">Current Year</label>
                    <select id="year">
                        <option value="1">1st Year</option>
                        <option value="2">2nd Year</option>
                        <option value="3">3rd Year</option>
                        <option value="4">4th Year</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="studentPhone">Phone Number</label>
                    <input type="text" id="studentPhone" placeholder="e.g., 9876543210">
                </div>

                <div class="form-group">
                    <label for="CGPA">CGPA</label>
                    <input type="number" step="0.01" min="0" max="10" id="CGPA" placeholder="e.g., 9.2">
                </div>

                <div id="addMsg" style="display:none; padding:12px 16px; border-radius:10px; margin-bottom:12px; font-weight:600;"></div>

                <button class="sbtbtn" id="submitBtn">✅ Add Student</button>

            </div>
        </div>

        <!-- CSRF token hidden field -->
        <input type="hidden" id="_csrf" value="<%= csrfToken %>">

<%- include ("../partials/footer.ejs") %>

<script>
    document.getElementById('submitBtn').addEventListener('click', async function() {
        const btn = this;
        const msgBox = document.getElementById('addMsg');

        const id     = document.getElementById('studentId').value.trim();
        const name   = document.getElementById('studentName').value.trim();
        const age    = document.getElementById('studentAge').value.trim();
        const branch = document.getElementById('branch').value;
        const year   = document.getElementById('year').value;
        const phone  = document.getElementById('studentPhone').value.trim();
        const cgpa   = document.getElementById('CGPA').value.trim();

        if (!id || !name || !phone) {
            msgBox.style.display = 'block';
            msgBox.style.background = 'rgba(220,53,69,0.15)';
            msgBox.style.color = '#ff6b7a';
            msgBox.style.border = '1px solid rgba(220,53,69,0.3)';
            msgBox.textContent = '⚠️ Student Roll Number, Name and Phone are required.';
            return;
        }

        btn.disabled = true;
        btn.textContent = 'Adding...';

        try {
            const res = await fetch('/students/addStudent', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'CSRF-Token': document.getElementById('_csrf').value
                },
                body: JSON.stringify({ id, name, age, branch, year, phone, cgpa })
            });
            const data = await res.json();

            msgBox.style.display = 'block';
            if (res.ok && data.success) {
                msgBox.style.background = 'rgba(40,167,69,0.15)';
                msgBox.style.color = '#5cb85c';
                msgBox.style.border = '1px solid rgba(40,167,69,0.3)';
                msgBox.textContent = '✅ ' + data.message;
                // Clear form
                ['studentId','studentName','studentAge','studentPhone','CGPA'].forEach(id => document.getElementById(id).value = '');
            } else {
                msgBox.style.background = 'rgba(220,53,69,0.15)';
                msgBox.style.color = '#ff6b7a';
                msgBox.style.border = '1px solid rgba(220,53,69,0.3)';
                msgBox.textContent = '❌ ' + (data.message || 'Failed to add student.');
            }
        } catch (err) {
            msgBox.style.display = 'block';
            msgBox.style.textContent = '❌ Network error. Please try again.';
        } finally {
            btn.disabled = false;
            btn.textContent = '✅ Add Student';
        }
    });
</script>