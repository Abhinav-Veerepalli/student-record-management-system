<%- include ("../partials/header.ejs") %>
<div class="page-title-bar">
    <div class="page-title-icon">📘</div>
    <div>
        <h2>Active Courses Library</h2>
        <p>Complete list of assigned courses — <%= courses.length %> record<%= courses.length !== 1 ? 's' : '' %> found</p>
    </div>
</div>

<div class="students_container">

    <% if (user && user.role === 'teacher') { %>
    <div class="student_card" style="display:flex; flex-direction:column; justify-content:center; align-items:center; border: 2px dashed var(--blue-200); background: rgba(0,0,0,0.02); min-height: 200px; cursor: pointer;" onclick="location.href='/courses/addCourse'">
        <div style="font-size: 3rem; margin-bottom: 10px;">➕</div>
        <h3 style="color:var(--text-dark)">Create New Course</h3>
    </div>
    <% } %>

    <% courses.forEach(function(course, i) { %>
        <div class="student_card" style="--i:<%= i %>; padding: 25px;">
            <div style="font-size:2.5rem; margin-bottom:15px;">📚</div>
            <h3 class="name" style="font-size: 1.4rem; color:var(--primary-accent); margin-bottom:8px;"><%= course.course_name %></h3>
            
            <p><strong>Code ID:</strong> #<%= course.course_id %></p>
            <p><strong>Lecturer:</strong> <%= course.teacher_name %></p>
            <p><strong>👥 Enrolled Students:</strong> <%= course.enrolled_count %></p>

            <% if (user && user.role === 'teacher') { %>
            <a href="/courses/addCourse" class="sbtbtn" style="text-align:center; text-decoration:none; display:inline-block; margin-top:20px; font-size: 0.85rem; padding: 12px; opacity: 0.8;">Add Another Course</a>
            <% } %>
        </div>
    <% }); %>

</div>

<%- include ("../partials/footer.ejs") %>
