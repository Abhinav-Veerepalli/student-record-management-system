<%- include ("../partials/header.ejs") %>

        <div class="page-title-bar">
            <div class="page-title-icon">🔍</div>
            <div>
                <h2>Search Student</h2>
                <p>Enter a Student ID to retrieve their record</p>
            </div>
        </div>

<div class="search_container">

    <div class="search_box">
        <h3>🔍 Find a Student</h3>
        <p>Enter the unique Student ID below</p>
        <form action="/students/searchStudent" method="POST">
            <input class="search_item" type="text" name="search_id" placeholder="e.g., AP21CSE001" required>
            <input type="hidden" name="identifier" value="false">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button id="search" type="submit">Search →</button>
        </form>
    </div>

    <div id="student_details">
        <%if(student!=null){%>
            <div class="student_card">
                <div class="id_name">
                    <h3 id="name"><%= student.name.toUpperCase() %></h3>
                    <p id="id"><strong>ID:</strong> <%= student.id.toUpperCase() %></p>
                </div>
                <p id="age"><strong>🎂 Age:</strong> <%= student.age %> years</p>
                <p id="phone"><strong>📞 Phone:</strong> <%= student.phone %></p>
                <div class="phone_year">
                    <p id="branch"><strong>Branch</strong><br><%= student.branch %></p>
                    <p id="year"><strong>Year</strong><br><%= student.year %></p>
                </div>
                <p class="cgpa">⭐ CGPA: <%= student.cgpa %></p>
            </div>
        <% } else { %>
            <script>
                if(typeof message !== 'undefined' && message)
                    alert("<%=message%>");
            </script>
        <% } %>
    </div>

</div>

<%- include ("../partials/footer.ejs") %>
