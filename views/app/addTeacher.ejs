<%- include("../partials/header.ejs") %>

<div class="page-title-bar">
    <div class="page-title-icon">👩‍🏫</div>
    <div>
        <h2>Add New Teacher</h2>
        <p>Register a teacher and assign them to a course. Credentials follow the student format.</p>
    </div>
</div>

<div class="form_container">
    <div class="add_teacher_form">
        <div class="form-header">
            <h2>Teacher Registration</h2>
            <p>Login format: <strong>phone@srms.edu</strong> / Password: <strong>Teacher ID</strong></p>
        </div>

        <div class="form-group">
            <label for="teacherId">Teacher Staff ID (used as password)</label>
            <input type="text" id="teacherId" placeholder="e.g., T2025101" required />
        </div>

        <div class="form-group">
            <label for="teacherName">Full Name</label>
            <input type="text" id="teacherName" placeholder="e.g., Dr. Jane Smith" required />
        </div>

        <div class="form-group">
            <label for="teacherPhone">Phone Number</label>
            <input type="text" id="teacherPhone" placeholder="e.g., 9876543210" required />
        </div>

        <div class="form-group">
            <label for="teacherEmail">Personal Email (for records)</label>
            <input type="email" id="teacherEmail" placeholder="e.g., jane@gmail.com" required />
        </div>

        <div class="form-group">
            <label for="department">Department</label>
            <select id="department">
                <option value="CSE">Computer Science</option>
                <option value="ECE">Electronics &amp; Comm.</option>
                <option value="MECH">Mechanical</option>
                <option value="CIVIL">Civil Engineering</option>
                <option value="EEE">Electrical</option>
            </select>
        </div>

        <div class="form-group">
            <label for="course_id">Allocated Course</label>
            <select id="course_id">
                <option value="">-- Select a Course (Optional) --</option>
                <% if(locals.courses) { %>
                    <% courses.forEach(course => { %>
                        <option value="<%= course.course_id %>"><%= course.course_name %></option>
                    <% }); %>
                <% } %>
            </select>
        </div>

        <div id="addMsg" style="display:none; padding:12px 16px; border-radius:10px; margin-bottom:12px; font-weight:600;"></div>

        <button class="sbtbtn" id="submitBtn">✅ Register Teacher</button>
    </div>
</div>

<!-- CSRF token hidden field -->
<input type="hidden" id="_csrf" value="<%= csrfToken %>">

<%- include("../partials/footer.ejs") %>

<script>
    document.getElementById('submitBtn').addEventListener('click', async function() {
        const btn = this;
        const msgBox = document.getElementById('addMsg');

        const id = document.getElementById('teacherId').value.trim();
        const name = document.getElementById('teacherName').value.trim();
        const phone = document.getElementById('teacherPhone').value.trim();
        const email = document.getElementById('teacherEmail').value.trim();
        const department = document.getElementById('department').value;
        const course_id = document.getElementById('course_id').value;

        if (!id || !name || !phone || !email) {
            msgBox.style.display = 'block';
            msgBox.style.background = 'rgba(220,53,69,0.15)';
            msgBox.style.color = '#ff6b7a';
            msgBox.style.border = '1px solid rgba(220,53,69,0.3)';
            msgBox.textContent = '⚠️ Staff ID, Name, Phone, and Email are required.';
            return;
        }

        btn.disabled = true;
        btn.textContent = 'Registering...';

        try {
            const res = await fetch('/manage/addTeacher', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'CSRF-Token': document.getElementById('_csrf').value
                },
                body: JSON.stringify({ id, name, phone, email, department, course_id })
            });

            const data = await res.json();
            msgBox.style.display = 'block';

            if (res.ok && data.success) {
                msgBox.style.background = 'rgba(40,167,69,0.15)';
                msgBox.style.color = '#5cb85c';
                msgBox.style.border = '1px solid rgba(40,167,69,0.3)';
                msgBox.textContent = '✅ ' + data.message;
                // Clear form
                ['teacherId','teacherName','teacherPhone','teacherEmail'].forEach(i => document.getElementById(i).value = '');
            } else {
                msgBox.style.background = 'rgba(220,53,69,0.15)';
                msgBox.style.color = '#ff6b7a';
                msgBox.style.border = '1px solid rgba(220,53,69,0.3)';
                msgBox.textContent = '❌ ' + (data.message || 'Failed to add teacher.');
            }
        } catch (err) {
            msgBox.style.display = 'block';
            msgBox.style.background = 'rgba(220,53,69,0.15)';
            msgBox.style.color = '#ff6b7a';
            msgBox.style.border = '1px solid rgba(220,53,69,0.3)';
            msgBox.textContent = '❌ Network error. Please try again.';
        } finally {
            btn.disabled = false;
            btn.textContent = '✅ Register Teacher';
        }
    });
</script>
