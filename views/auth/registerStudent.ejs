<%- include('../partials/login_header') %>
<% if (typeof message !== 'undefined' && message) { %>
  <script>
    window.alert("<%= message %>");
  </script>
<% } %>
<div class="register-page" style="margin-top: 50px; margin-bottom: 50px;">
    <div style="text-align:center;margin-bottom:8px;font-size:2.4rem;">🎓</div>
    <h1 class="login-title">Student Registration</h1>
    <p class="login-subtitle">Register to access your student profile</p>

    <div class="register-card" style="max-width: 500px;">
        <form class="login-form" action="/register/student" method="POST">
            
            <div class="form-field">
                <label for="name">Full Name</label>
                <input type="text" id="name" name="name" required>
            </div>

            <div class="form-field">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required>
            </div>

            <div class="form-field">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" required>
            </div>

            <div class="form-field">
                <label for="roll_number">Roll Number</label>
                <input type="text" id="roll_number" name="roll_number" required>
            </div>

            <div class="form-field">
                <label for="age">Age</label>
                <input type="number" id="age" name="age" required>
            </div>

            <div class="form-field">
                <label for="phone_no">Phone Number</label>
                <input type="text" id="phone_no" name="phone_no" required>
            </div>

            <div class="form-field">
                <label for="cgpa">CGPA</label>
                <input type="number" step="0.01" id="cgpa" name="cgpa" required>
            </div>

            <div class="form-field">
                <label for="current_year">Current Year</label>
                <input type="number" id="current_year" name="current_year" required>
            </div>

            <div class="form-field">
                <label for="branch">Branch</label>
                <input type="text" id="branch" name="branch" required>
            </div>

            <button type="submit" class="login-button">
                Register Student
            </button>
        </form>
    </div>
</div>
<%- include('../partials/footer') %>
