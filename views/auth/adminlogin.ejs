<%- include('../partials/login_header') %>
<% if (message) { %>
  <script>
    window.alert("<%= message %>");
  </script>
<% } %>

<div class="login-page">

    <div style="text-align:center;margin-bottom:8px;font-size:2.4rem;">⚙️</div>
    <h1 class="login-title">Admin Login</h1>
    <p class="login-subtitle">Sign in with your administrator credentials</p>

    <div class="login-card">
        <form class="login-form" action="/adminLogin" method="POST">

            <div class="form-field">
                <label for="email">Email Address</label>
                <input
                    type="email"
                    id="email"
                    name="email"
                    placeholder="admin@srms.edu"
                    required
                >
            </div>

            <div class="form-field">
                <label for="password">Password</label>
                <input
                    type="password"
                    id="password"
                    name="password"
                    placeholder="••••••••"
                    required
                >
            </div>

            <button type="submit" class="login-button">
                Sign In →
            </button>

        </form>
    </div>

    <p style="margin-top:20px;font-size:.82rem;color:var(--text-soft);">
        Not an Admin? <a href="/role" style="color:var(--blue-500);font-weight:600;">Go Back</a>
    </p>

</div>

<%- include('../partials/footer') %>
